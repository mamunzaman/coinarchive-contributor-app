# Full CoinArchive REST API base (preferred for auth + submissions + admin).
# Local: https://coins.local/wp-json/coinarchive/v1
# Production: https://api.coinarchive.eu/wp-json/coinarchive/v1
VITE_API_BASE_URL=https://coins.local/wp-json/coinarchive/v1

# Optional WordPress site root. Used only when VITE_API_BASE_URL is unset.
# Auth, submissions, and admin clients all resolve to /wp-json/coinarchive/v1 from this.
# Local: https://coins.local
# Production: https://api.coinarchive.eu
# VITE_WP_API_BASE_URL=https://coins.local

# Local dev fallback for legacy manual admin ID forms (AdminApprovePage 404 fallback only).
VITE_ADMIN_API_KEY=local-dev-key-123
